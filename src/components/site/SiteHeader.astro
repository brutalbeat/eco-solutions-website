---
import Container from '~/components/site/Container.astro';
import { company, companyLinks } from '~/data/company';
---

<header class="sticky top-0 z-50 border-b border-primary/30 bg-slate-950">
  <Container class="py-3">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="flex items-center font-semibold tracking-tight text-white shrink-0">
        <img
          src="/axiomtransparent.png"
          alt={`${company.name} logo`}
          class="h-[120px] sm:h-[138px] md:h-[154px] w-auto rounded-md"
          loading="lazy"
        />
      </a>

      <nav class="hidden flex-1 items-center justify-center gap-12 md:flex" aria-label="Primary">
        <a
          class="text-lg font-semibold text-white hover:text-accent"
          href="/"
        >
          Home
        </a>
        <a
          class="text-lg font-semibold text-white hover:text-accent"
          href="/services"
        >
          Services
        </a>
        <a
          class="text-lg font-semibold text-white hover:text-accent"
          href="/about"
        >
          About Us
        </a>
        <a
          class="text-lg font-semibold text-white hover:text-accent"
          href={companyLinks.careers}
        >
          Careers
        </a>
      </nav>

      <div class="hidden items-center gap-2 md:flex shrink-0">
        <a class="btn-primary px-7 py-3.5 text-lg font-semibold" href="/#contact">Contact</a>
      </div>

      <details class="md:hidden">
        <summary class="btn btn-secondary list-none px-4 py-2">
          <span class="sr-only">Open menu</span>
          Menu
        </summary>
        <div class="absolute left-0 right-0 top-[60px] border-b border-primary/30 bg-slate-950">
          <Container class="py-4">
            <nav class="grid gap-3" aria-label="Mobile">
              <a class="py-2 text-sm font-medium text-white" href="/">Home</a>
              <a class="py-2 text-sm font-medium text-white" href="/services">Services</a>
              <a class="py-2 text-sm font-medium text-white" href="/about">About Us</a>
              <a class="py-2 text-sm font-medium text-white" href={companyLinks.careers}>Careers</a>
              <a class="btn-primary mt-2 w-full" href="/#contact">Contact</a>
            </nav>
          </Container>
        </div>
      </details>
    </div>
  </Container>
</header>
